# AI providers (required for document classification)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Firebase (required for Vercel / persistent storage)
# Create project at console.firebase.google.com, generate a service account key.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Optional — local development overrides
# Point to a writable directory for local fs fallback (leave unset to use .smartcomprovante-data/)
# On Vercel set this to /tmp so ephemeral writes go to the writable temp area.
# SMARTCOMPROVANTE_DATA_DIR=/tmp

# Logging level: debug | info | warn | error
LOG_LEVEL=debug
